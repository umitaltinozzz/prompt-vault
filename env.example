# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=prompt_vault

# Database URL
# Docker Compose kullanıyorsanız:
DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/prompt_vault
# Yerel geliştirme için (sadece DB Docker'da):
# DATABASE_URL=postgresql://postgres:your_strong_password_here@localhost:5433/prompt_vault

# NextAuth
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Medya yükleme dizini
UPLOAD_DIR=./public/uploads
